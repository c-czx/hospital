<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.mapper.MedicalRecordMapper">
    <resultMap id="MedicalRecordResultMap" type="com.hospital.entity.MedicalRecord">
        <id column="id" property="id" />
        <result column="patient_id" property="patientId" />
        <result column="doctor_id" property="doctorId" />
        <result column="diagnosis" property="diagnosis" />
        <result column="treatment" property="treatment" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <insert id="insert" parameterType="com.hospital.entity.MedicalRecord">
        INSERT INTO medical_record (patient_id, doctor_id, diagnosis, treatment, created_at)
        VALUES (#{patientId}, #{doctorId}, #{diagnosis}, #{treatment}, #{createdAt})
    </insert>

    <update id="update" parameterType="com.hospital.entity.MedicalRecord">
        UPDATE medical_record
        SET patient_id = #{patientId}, doctor_id = #{doctorId}, diagnosis = #{diagnosis}, treatment = #{treatment}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM medical_record WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="MedicalRecordResultMap">
        SELECT * FROM medical_record WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="MedicalRecordResultMap">
        SELECT * FROM medical_record
    </select>

    <select id="findByPatientId" parameterType="java.lang.Long" resultMap="MedicalRecordResultMap">
        SELECT * FROM medical_record WHERE patient_id = #{patientId}
    </select>

    <select id="findByDoctorId" parameterType="java.lang.Long" resultMap="MedicalRecordResultMap">
        SELECT * FROM medical_record WHERE doctor_id = #{doctorId}
    </select>
</mapper>