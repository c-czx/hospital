<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.mapper.BillingMapper">
    <resultMap id="BillingResultMap" type="com.hospital.entity.Billing">
        <id column="id" property="id" />
        <result column="patient_id" property="patientId" />
        <result column="amount" property="amount" />
        <result column="status" property="status" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <insert id="insert" parameterType="com.hospital.entity.Billing">
        INSERT INTO billing (patient_id, amount, status, created_at)
        VALUES (#{patientId}, #{amount}, #{status}, #{createdAt})
    </insert>

    <update id="update" parameterType="com.hospital.entity.Billing">
        UPDATE billing
        SET patient_id = #{patientId}, amount = #{amount}, status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM billing WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BillingResultMap">
        SELECT * FROM billing WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BillingResultMap">
        SELECT * FROM billing
    </select>

    <select id="findByPatientId" parameterType="java.lang.Long" resultMap="BillingResultMap">
        SELECT * FROM billing WHERE patient_id = #{patientId}
    </select>

    <select id="findByStatus" parameterType="java.lang.String" resultMap="BillingResultMap">
        SELECT * FROM billing WHERE status = #{status}
    </select>
</mapper>