<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.mapper.UserMapper">
    <resultMap id="UserResultMap" type="com.hospital.entity.User">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="phone" property="phone" />
        <result column="password" property="password" />
        <result column="role" property="role" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <insert id="insert" parameterType="com.hospital.entity.User">
        INSERT INTO users (name, phone, password, role, created_at)
        VALUES (#{name}, #{phone}, #{password}, #{role}, #{createdAt})
    </insert>

    <update id="update" parameterType="com.hospital.entity.User">
        UPDATE users
        SET name = #{name}, phone = #{phone}, password = #{password}, role = #{role}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM users WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="UserResultMap">
        SELECT * FROM users WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="UserResultMap">
        SELECT * FROM users
    </select>

    <select id="findByPhone" parameterType="java.lang.String" resultMap="UserResultMap">
        SELECT * FROM users WHERE phone = #{phone}
    </select>

    <select id="findByRole" parameterType="java.lang.String" resultMap="UserResultMap">
        SELECT * FROM users WHERE role = #{role}
    </select>

    <select id="existsByPhone" parameterType="java.lang.String" resultType="java.lang.Boolean">
        SELECT COUNT(*) > 0 FROM users WHERE phone = #{phone}
    </select>
</mapper>