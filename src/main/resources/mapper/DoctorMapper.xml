<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.mapper.DoctorMapper">
    <resultMap id="DoctorResultMap" type="com.hospital.entity.Doctor">
        <id column="id" property="id" />
        <result column="specialty" property="specialty" />
        <result column="title" property="title" />
        <result column="schedule" property="schedule" />
        <association property="user" javaType="com.hospital.entity.User">
            <id column="user_id" property="id" />
        </association>
        <association property="department" javaType="com.hospital.entity.Department">
            <id column="department_id" property="id" />
        </association>
    </resultMap>

    <insert id="insert" parameterType="com.hospital.entity.Doctor">
        INSERT INTO doctors (user_id, department_id, title, specialty, schedule, created_at)
        VALUES (#{user.id}, #{department.id}, #{title}, #{specialty}, #{schedule}, NOW())
    </insert>

    <update id="update" parameterType="com.hospital.entity.Doctor">
        UPDATE doctors
        SET user_id = #{user.id}, department_id = #{department.id}, title = #{title}, specialty = #{specialty}, schedule = #{schedule}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM doctors WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="DoctorResultMap">
        SELECT * FROM doctors WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="DoctorResultMap">
        SELECT * FROM doctors
    </select>

    <select id="findByDepartmentId" parameterType="java.lang.Long" resultMap="DoctorResultMap">
        SELECT * FROM doctors WHERE department_id = #{departmentId}
    </select>

    <select id="findByUserId" parameterType="java.lang.Long" resultMap="DoctorResultMap">
        SELECT * FROM doctors WHERE user_id = #{userId}
    </select>
</mapper>