<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.mapper.PrescriptionMapper">
    <resultMap id="PrescriptionResultMap" type="com.hospital.entity.Prescription">
        <id column="id" property="id" />
        <result column="patient_id" property="patientId" />
        <result column="doctor_id" property="doctorId" />
        <result column="medicines" property="medicines" />
        <result column="dosage" property="dosage" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <insert id="insert" parameterType="com.hospital.entity.Prescription">
        INSERT INTO prescription (patient_id, doctor_id, medicines, dosage, created_at)
        VALUES (#{patientId}, #{doctorId}, #{medicines}, #{dosage}, #{createdAt})
    </insert>

    <update id="update" parameterType="com.hospital.entity.Prescription">
        UPDATE prescription
        SET patient_id = #{patientId}, doctor_id = #{doctorId}, medicines = #{medicines}, dosage = #{dosage}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM prescription WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="PrescriptionResultMap">
        SELECT * FROM prescription WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="PrescriptionResultMap">
        SELECT * FROM prescription
    </select>

    <select id="findByPatientId" parameterType="java.lang.Long" resultMap="PrescriptionResultMap">
        SELECT * FROM prescription WHERE patient_id = #{patientId}
    </select>

    <select id="findByDoctorId" parameterType="java.lang.Long" resultMap="PrescriptionResultMap">
        SELECT * FROM prescription WHERE doctor_id = #{doctorId}
    </select>
</mapper>