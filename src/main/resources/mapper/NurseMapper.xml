<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.mapper.NurseMapper">
    <resultMap id="NurseResultMap" type="com.hospital.entity.Nurse">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="department_id" property="departmentId" />
        <result column="education" property="education" />
        <result column="experience" property="experience" />
        <result column="status" property="status" />
    </resultMap>

    <insert id="insert" parameterType="com.hospital.entity.Nurse">
        INSERT INTO nurse (user_id, department_id, education, experience, status)
        VALUES (#{userId}, #{departmentId}, #{education}, #{experience}, #{status})
    </insert>

    <update id="update" parameterType="com.hospital.entity.Nurse">
        UPDATE nurse
        SET user_id = #{userId}, department_id = #{departmentId}, education = #{education}, 
            experience = #{experience}, status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM nurse WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="NurseResultMap">
        SELECT * FROM nurse WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="NurseResultMap">
        SELECT * FROM nurse
    </select>

    <select id="findByUserId" parameterType="java.lang.Long" resultMap="NurseResultMap">
        SELECT * FROM nurse WHERE user_id = #{userId}
    </select>
</mapper>